{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minecraft P2P Connector",
  "version": "0.2.0",
  "identifier": "com.minecraft.p2pconnector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Minecraft P2P Connector",
        "width": 1200,
        "height": 730,
        "minWidth": 1200,
        "minHeight": 730,
        "maxWidth": 1200,
        "maxHeight": 730,
        "resizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "targets": ["nsis", "msi"],
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
